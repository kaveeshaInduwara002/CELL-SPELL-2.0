# =============================================
# Cell Spell 2.0 — Environment Variables
# =============================================
# Copy this file to .env and fill in your values.
# For Vercel production: set these in Dashboard > Settings > Environment Variables.
# =============================================

# --- Supabase (Client-side — safe to expose) ---
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# --- Supabase (Server-side ONLY — NEVER expose to client) ---
# Used by Vercel Serverless Functions to bypass RLS.
# Find it in: Supabase Dashboard > Settings > API > service_role key
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Brevo SMTP (Server-side ONLY) ---
# Used by Vercel Serverless Functions to send confirmation emails.
# Sign up at https://www.brevo.com, go to Settings > SMTP & API > SMTP.
BREVO_SMTP_USER=your-brevo-smtp-login
BREVO_SMTP_KEY=your-brevo-smtp-key
BREVO_SENDER_EMAIL=your-verified-sender@example.com
