# =============================================
# Cell Spell 2.0 — Environment Variables
# =============================================
# Copy this file to .env and fill in your values.
# For Vercel production: set these in Dashboard > Settings > Environment Variables.
# =============================================

# --- Supabase (Client-side — safe to expose) ---
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# --- Supabase (Server-side ONLY — NEVER expose to client) ---
# Used by Vercel Serverless Functions to bypass RLS.
# Find it in: Supabase Dashboard > Settings > API > service_role key
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Resend (Server-side ONLY) ---
# Used by Vercel Serverless Functions to send emails.
# Get your key at: https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key-here
